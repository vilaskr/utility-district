rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    // Community Tools
    match /community_tools/{toolId} {
      function isValidTool(data) {
        return data.name is string && data.name.size() <= 100 &&
               data.tagline is string && data.tagline.size() <= 200 &&
               data.url is string && data.url.size() <= 500 &&
               data.creatorId == request.auth.uid &&
               data.creatorName is string &&
               data.category in ['PRODUCTIVITY', 'CREATOR', 'SHARING', 'FINANCE', 'AI', 'EXPERIMENTAL', 'FUN', 'DEVELOPER', 'STUDY'];
      }

      allow list, get: if true; // Publicly readable
      
      allow create: if isSignedIn() && isValidTool(request.resource.data) &&
                      request.resource.data.upvotes == 0;
      
      allow update: if isSignedIn() && (
        // Allow upvoting
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['upvotes'])) ||
        // Allow owner to update metadata
        (isOwner(resource.data.creatorId) && isValidTool(request.resource.data))
      );
      
      allow delete: if isOwner(resource.data.creatorId);
    }

    // Creator Profiles
    match /creators/{userId} {
      allow get: if true;
      allow write: if isOwner(userId);
    }
  }
}
